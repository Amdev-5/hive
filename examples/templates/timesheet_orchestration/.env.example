# Timesheet Orchestration Agent — Environment Variables
# Copy to .env and fill values, then run:
#   set -a; source .env; set +a

# LLM Provider (Zhipu GLM)
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# Slack (2-way: send reminders + read timesheet submissions)
# Get from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
# Required scopes: chat:write, channels:history, channels:read
SLACK_BOT_TOKEN=

# Telegram (1-way: push notifications and reminders)
# Get from: @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=

# Email via Resend (1-way: executive report delivery)
# Get from: resend.com → Dashboard → API Keys → Create
RESEND_API_KEY=
# Must be a verified sender/domain in Resend (e.g. reports@yourcompany.com)
EMAIL_FROM=

# Credential encryption (auto-generated, keep secret)
HIVE_CREDENTIAL_KEY=
